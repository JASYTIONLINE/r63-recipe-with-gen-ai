{
  "recipes": [
    {
      "id": "recipe_001",
      "name": "Turmeric Chicken Power Bowl",
      "servings": 1,
      "short_description": "Seasoned chicken with turmeric and garlic over sautéed zucchini, spinach, and avocado, finished with chia.",
      "ingredients": [
        { "name": "Chicken breast", "amount": "8 oz", "grams": 227, "prep": "diced" },
        { "name": "Spinach", "amount": "2 cups", "grams": 60, "prep": "whole leaves" },
        { "name": "Zucchini", "amount": "1 medium", "grams": 150, "prep": "sliced" },
        { "name": "Avocado", "amount": "1/2 medium", "grams": 75, "prep": "sliced" },
        { "name": "Olive oil", "amount": "1 tbsp", "grams": 14, "prep": "liquid" },
        { "name": "Garlic", "amount": "2 cloves", "grams": 6, "prep": "minced" },
        { "name": "Ground turmeric", "amount": "1/2 tsp", "grams": 1, "prep": "powder" },
        { "name": "Black pepper", "amount": "1/4 tsp", "grams": 0.5, "prep": "ground" },
        { "name": "Chia seeds", "amount": "1 tbsp", "grams": 12, "prep": "whole" }
      ],
      "macros": {
        "protein_g": 45,
        "carbs_g": 10,
        "fat_g": 22,
        "calories": 430,
        "omega_3_6_ratio": 11
      },
      "instructions": "Heat half the olive oil in a pan over medium heat. Add minced garlic and cook briefly. Add diced chicken with turmeric and black pepper, cook until fully done (165°F internal). Remove and set aside. In the same pan, add remaining oil, cook sliced zucchini until slightly soft, then add spinach and cook until wilted. Plate vegetables, top with chicken, add sliced avocado, and finish with chia seeds."
    },
